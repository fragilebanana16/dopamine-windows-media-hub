n index="12" value="57"/><column index="13" value="78"/><column index="14" value="263"/><column index="15" value="85"/><column index="16" value="78"/><column index="17" value="78"/><column index="18" value="71"/><column index="19" value="64"/><column index="20" value="39"/><column index="21" value="71"/><column index="22" value="151"/><column index="23" value="151"/><column index="24" value="151"/><column index="25" value="151"/><column index="26" value="99"/><column index="27" value="183"/><column index="28" value="113"/><column index="29" value="155"/><column index="30" value="50"/><column index="31" value="39"/><column index="32" value="71"/><column index="33" value="71"/><column index="34" value="151"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="95"/><column index="2" value="29"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- 1. 彻底清理旧的 FTS
DROP TABLE IF EXISTS TrackFTS;
DROP TRIGGER IF EXISTS TrackFTS_insert;
DROP TRIGGER IF EXISTS TrackFTS_update;
DROP TRIGGER IF EXISTS TrackFTS_delete;

-- 2. 创建**简单模式**的 FTS5（最容易成功）
CREATE VIRTUAL TABLE IF NOT EXISTS TrackFTS USING fts5(
    TrackID UNINDEXED,
    TrackTitle,
    Artists,
    AlbumTitle,
    AlbumArtists,
    Genres,
    tokenize='unicode61'
);

-- 3. 手动把所有数据灌进去（这是关键！）
INSERT INTO TrackFTS(TrackID, TrackTitle, Artists, AlbumTitle, AlbumArtists, Genres)
SELECT TrackID, TrackTitle, Artists, AlbumTitle, AlbumArtists, Genres 
FROM Track;

-- 4. 查看是否灌成功了
SELECT COUNT(*) FROM TrackFTS;

-- 5. 测试搜索
SELECT TrackTitle, Artists 
FROM TrackFTS 
WHERE TrackFTS MATCH '一  ';

SELECT 'track' as type, TrackTitle as title, Artists as subtitle
FROM Track WHERE TrackTitle LIKE '%p%' OR Artists LIKE '%p%'
-- 6. 再测试英文
-- SELECT TrackTitle, Artists 
-- FROM TrackFTS 
-- WHERE TrackFTS MATCH 'zom' 
-- LIMIT 5;


SELECT 'track' AS type, TrackID, TrackTitle, Artists, AlbumTitle, AlbumArtists, Genres, FileName
FROM Track
WHERE TrackTitle LIKE '%鹿%'
   OR Artists LIKE '%鹿%'
   OR AlbumTitle LIKE '%鹿%'
   OR AlbumArtists LIKE '%鹿%'
   OR Genres LIKE '%鹿%'
   OR FileName LIKE '%鹿%';
   
   
SELECT * FROM Track
WHERE TrackTitle LIKE '%鹿%'
   OR Artists LIKE '%鹿%'
   OR AlbumTitle LIKE '%鹿%'
   OR AlbumArtists LIKE '%鹿%'
   OR Genres LIKE '%鹿%'
   OR FileName LIKE '%鹿%';</sql><current_tab id="0"/></tab_sql></sqlb_project>

<UserControl x:Class="Dopamine.Controls.ControllerPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dopamine.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- ══════════════════════════════════════
             BACKGROUND & COLOR TOKENS
        ══════════════════════════════════════ -->
        <LinearGradientBrush x:Key="ShadedBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0.0" Color="#000A0F1D" />
            <GradientStop Offset="0.4" Color="#550A0F1D" />
            <GradientStop Offset="0.75" Color="#AA0A0F1D" />
            <GradientStop Offset="1.0"  Color="#E00A0F1D" />
        </LinearGradientBrush>

        <!-- Progress gradient (sky → indigo) -->
        <LinearGradientBrush x:Key="ProgressGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0.0" Color="#FF38BDF8" />
            <GradientStop Offset="1.0" Color="#FF818CF8" />
        </LinearGradientBrush>

        <!-- Play button gradient -->
        <LinearGradientBrush x:Key="PlayButtonGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#FF38BDF8" />
            <GradientStop Offset="1.0" Color="#FF818CF8" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TrackBackgroundBrush"  Color="#22FFFFFF" />
        <SolidColorBrush x:Key="IconNormalBrush"       Color="#AAFFFFFF" />
        <SolidColorBrush x:Key="IconActiveBrush"       Color="#FF38BDF8" />
        <SolidColorBrush x:Key="IconHoverBrush"        Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TimecodesBrush"        Color="#88FFFFFF" />
        <SolidColorBrush x:Key="PopupBackgroundBrush"  Color="#F01C1C2A" />

        <!-- ══════════════════════════════════════
             ICON GEOMETRY DATA
             All icons drawn on a 10×10 grid.
             Fill-based: Play, Pause, Stop
             Stroke-based: everything else
        ══════════════════════════════════════ -->

        <!-- Transport -->
        <Geometry x:Key="PlayIcon">M 2,1 L 9,5 L 2,9 Z</Geometry>
        <Geometry x:Key="PauseIcon">M 1,1 H 4 V 9 H 1 Z M 6,1 H 9 V 9 H 6 Z</Geometry>
        <Geometry x:Key="StopIcon">M 1,1 H 9 V 9 H 1 Z</Geometry>

        <!-- Volume / Audio -->
        <Geometry x:Key="UnmuteIcon">
            M 0,3.5 H 2.8 L 5.2,1.5 V 8.5 L 2.8,6.5 H 0 Z
            M 7,3.2 Q 9.2,5 7,6.8
            M 8,1.5 Q 11,5 8,8.5
        </Geometry>
        <Geometry x:Key="MuteIcon">
            M 0,3.5 H 2.8 L 5.2,1.5 V 8.5 L 2.8,6.5 H 0 Z
            M 7.5,3.5 L 10,6.5
            M 10,3.5 L 7.5,6.5
        </Geometry>
        <!-- Equalizer bars (AudioMenu) -->
        <Geometry x:Key="AudioMenuIcon">
            M 1.5,9 V 4
            M 5,9 V 6
            M 8.5,9 V 2
            M 0,6 H 3
            M 3.5,7.5 H 6.5
            M 7,4.5 H 10
        </Geometry>

        <!-- Playback extras -->
        <Geometry x:Key="RepeatIcon">
            M 2,4 V 2.5 Q 2,1 3.5,1 H 8.5
            M 7,0 L 9.5,2 L 7,4
            M 8,6 V 7.5 Q 8,9 6.5,9 H 1.5
            M 3,10 L 0.5,8 L 3,6
        </Geometry>
        <Geometry x:Key="ScrubbingIcon">
            M 0.5,5 H 9.5
            M 5,2 V 8
            M 2.5,3.5 V 6.5
            M 7.5,3.5 V 6.5
        </Geometry>
        <Geometry x:Key="VerticalSyncIcon">
            M 5,1 A 4,4 0 0 1 9,5
            M 5,1 L 3.2,3 M 5,1 L 6.8,3
            M 5,9 A 4,4 0 0 1 1,5
            M 5,9 L 6.8,7 M 5,9 L 3.2,7
        </Geometry>

        <!-- UI chrome -->
        <Geometry x:Key="CloseIcon">M 1.5,1.5 L 8.5,8.5 M 8.5,1.5 L 1.5,8.5</Geometry>
        <Geometry x:Key="ToggleFullscreenIcon">
            M 0,3 V 0 H 3
            M 7,0 H 10 V 3
            M 10,7 V 10 H 7
            M 3,10 H 0 V 7
        </Geometry>
        <Geometry x:Key="OpenDebugIcon">
            M 5,0.5 A 4.5,4.5 0 1 0 5.001,0.5 Z
            M 5,4 V 7
            M 5,2.8 A 0.3,0.3 0 1 0 5.001,2.8 Z
        </Geometry>
        <Geometry x:Key="OpenMenuIcon">
            M 0.5,2.5 H 9.5
            M 0.5,5   H 9.5
            M 0.5,7.5 H 9.5
        </Geometry>

        <!-- ══════════════════════════════════════
             POSITION SLIDER (progress bar)
             Gradient fill on played portion,
             white circle thumb with glow.
        ══════════════════════════════════════ -->
        <ControlTemplate x:Key="PositionSliderThumbTemplate" TargetType="{x:Type Thumb}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse x:Name="grip" Width="12" Height="12" Fill="White">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#38BDF8" BlurRadius="8" ShadowDepth="0" Opacity="0.0"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="grip" Property="Width"  Value="14"/>
                    <Setter TargetName="grip" Property="Height" Value="14"/>
                    <Setter TargetName="grip" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#38BDF8" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="grip" Property="Width"  Value="16"/>
                    <Setter TargetName="grip" Property="Height" Value="16"/>
                    <Setter TargetName="grip" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#818CF8" BlurRadius="14" ShadowDepth="0" Opacity="0.85"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="grip" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PositionSliderTemplate" TargetType="{x:Type Slider}">
            <Border Background="Transparent" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{TemplateBinding MinHeight}"/>
                    </Grid.RowDefinitions>
                    <!-- Track layers -->
                    <DockPanel LastChildFill="True" VerticalAlignment="Center" Margin="6,0">
                        <!-- Played (gradient) -->
                        <Border x:Name="PART_SelectionRange" ClipToBounds="True"
                                Height="3" CornerRadius="1.5">
                            <Rectangle RadiusX="1.5" RadiusY="1.5" Margin="0,0,-10,0"
                                       Fill="{StaticResource ProgressGradientBrush}"/>
                        </Border>
                        <!-- Remaining (dim white) -->
                        <Border ClipToBounds="True" Height="3" CornerRadius="1.5">
                            <Rectangle RadiusX="1.5" RadiusY="1.5" Margin="10,0,0,0"
                                       Fill="{StaticResource TrackBackgroundBrush}"/>
                        </Border>
                    </DockPanel>
                    <!-- Thumb -->
                    <Track x:Name="PART_Track">
                        <Track.Thumb>
                            <Thumb x:Name="Thumb" Focusable="False"
                                   Width="{TemplateBinding MinHeight}"
                                   Height="{TemplateBinding MinHeight}"
                                   OverridesDefaultStyle="True"
                                   Template="{StaticResource PositionSliderThumbTemplate}"
                                   VerticalAlignment="Center"/>
                        </Track.Thumb>
                    </Track>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="PositionSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderBrush"           Value="Transparent"/>
            <Setter Property="MinHeight"             Value="20"/>
            <Setter Property="MaxHeight"             Value="20"/>
            <Setter Property="Height"                Value="20"/>
            <Setter Property="Minimum"               Value="0"/>
            <Setter Property="AutoToolTipPlacement"  Value="None"/>
            <Setter Property="IsMoveToPointEnabled"  Value="True"/>
            <Setter Property="VerticalAlignment"     Value="Center"/>
            <Setter Property="SelectionStart"        Value="0"/>
            <Setter Property="SelectionEnd"          Value="{Binding Path=Value, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="Template"              Value="{StaticResource PositionSliderTemplate}"/>
        </Style>

        <!-- ══════════════════════════════════════
             CUSTOM SLIDER (volume / balance / speed)
        ══════════════════════════════════════ -->
        <ControlTemplate x:Key="CustomSliderThumbTemplate" TargetType="{x:Type Thumb}">
            <Ellipse x:Name="grip" Width="10" Height="10" Fill="White">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#38BDF8" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <ControlTemplate.Triggers>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="grip" Property="Width"  Value="12"/>
                    <Setter TargetName="grip" Property="Height" Value="12"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="CustomSliderTemplate" TargetType="{x:Type Slider}">
            <Border Background="Transparent" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{TemplateBinding MinHeight}"/>
                    </Grid.RowDefinitions>
                    <DockPanel LastChildFill="True" VerticalAlignment="Center" Margin="5,0">
                        <Border x:Name="PART_SelectionRange" ClipToBounds="True"
                                Height="3" CornerRadius="1.5">
                            <Rectangle RadiusX="1.5" RadiusY="1.5" Margin="0,0,-8,0"
                                       Fill="{StaticResource ProgressGradientBrush}"/>
                        </Border>
                        <Border ClipToBounds="True" Height="3" CornerRadius="1.5">
                            <Rectangle RadiusX="1.5" RadiusY="1.5" Margin="8,0,0,0"
                                       Fill="{StaticResource TrackBackgroundBrush}"/>
                        </Border>
                    </DockPanel>
                    <Track x:Name="PART_Track">
                        <Track.Thumb>
                            <Thumb Focusable="False"
                                   Width="{TemplateBinding MinHeight}"
                                   Height="{TemplateBinding MinHeight}"
                                   OverridesDefaultStyle="True"
                                   Template="{StaticResource CustomSliderThumbTemplate}"
                                   VerticalAlignment="Center"/>
                        </Track.Thumb>
                    </Track>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="CustomSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="MinHeight"            Value="20"/>
            <Setter Property="Height"               Value="20"/>
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="SelectionStart"       Value="0"/>
            <Setter Property="SelectionEnd"         Value="{Binding Path=Value, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="Template"             Value="{StaticResource CustomSliderTemplate}"/>
        </Style>

        <!-- ══════════════════════════════════════
             MODERN BUTTON STYLE
             Rounded, subtle hover fill, scale on press.
        ══════════════════════════════════════ -->
        <Style x:Key="ModernButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource IconNormalBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}"
                        RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource IconHoverBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="0.92" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="0.92" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.0" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ══════════════════════════════════════
             PLAY BUTTON STYLE
             Larger, gradient background, glow shadow.
        ══════════════════════════════════════ -->
        <Style x:Key="PlayButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Padding"         Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="#FF0D1117"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bg" CornerRadius="13"
                        Padding="{TemplateBinding Padding}"
                        Background="{StaticResource PlayButtonGradientBrush}"
                        RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#38BDF8" BlurRadius="14"
                                          ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="0.93" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="0.93" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="bg"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.8" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="bg"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1.0" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ══════════════════════════════════════
             MODERN TOGGLE BUTTON STYLE
             Same as button + IsChecked → blue tint.
        ══════════════════════════════════════ -->
        <Style x:Key="ModernToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource IconNormalBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}"
                        RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource IconHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1838BDF8"/>
                                <Setter Property="Foreground" Value="{StaticResource IconActiveBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked"   Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="#2838BDF8"/>
                            </MultiTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="0.92" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="0.92" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="scale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.0" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ══════════════════════════════════════
             PROGRESS BAR STYLE (indeterminate/buffering)
        ══════════════════════════════════════ -->
        <Style x:Key="GradientProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height"           Value="3"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Background"       Value="#22FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="1.5">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="1.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#FF38BDF8"/>
                                        <GradientStop Offset="1" Color="#FF818CF8"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Name="Controls" Visibility="Visible" Height="220" Background="{x:Null}">

        <!-- Gradient overlay background -->
        <Canvas IsHitTestVisible="False" Background="{DynamicResource ShadedBackgroundBrush}" />

        <Grid VerticalAlignment="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- ── Row 0: Position Slider ── -->
            <Slider Name="PositionSlider"
                    Style="{DynamicResource PositionSliderStyle}"
                    Grid.Row="0" Margin="12,0" Cursor="Hand"/>

            <!-- ── Row 1: Timecodes + buffering ── -->
            <DockPanel Name="ProgressPanel" Grid.Row="1"
                       LastChildFill="True" Margin="20,0">

                <TextBlock Width="100" DockPanel.Dock="Left"
                           Foreground="{StaticResource TimecodesBrush}"
                           FontFamily="Consolas" FontSize="11"
                           Text="00:00:00" VerticalAlignment="Center"/>

                <TextBlock Width="100" DockPanel.Dock="Right"
                           Foreground="{StaticResource TimecodesBrush}"
                           FontFamily="Consolas" FontSize="11"
                           Text="10:00:00" TextAlignment="Right" VerticalAlignment="Center"/>

                <Grid Width="500">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" TextAlignment="Center"
                               Foreground="#55FFFFFF" FontSize="10"
                               Text="Txx" ToolTip="Buffering Progress"/>
                    <ProgressBar Grid.Column="1" VerticalAlignment="Center"
                                 Style="{StaticResource GradientProgressBarStyle}"
                                 Value="13" IsIndeterminate="True"/>
                    <ProgressBar Grid.Column="2" VerticalAlignment="Center"
                                 Style="{StaticResource GradientProgressBarStyle}"
                                 Value="42" IsIndeterminate="True"/>
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" TextAlignment="Center"
                               Foreground="#55FFFFFF" FontSize="10" Text="Progress"/>
                </Grid>
            </DockPanel>

            <!-- ── Row 2: Controls (Left | Center | Right) ── -->
            <Grid Name="ControlsPanel" Grid.Row="2" Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: sync · scrub · audio menu · mute · CC -->
                <DockPanel Name="LeftControls" HorizontalAlignment="Left"
                           Grid.Column="0" VerticalAlignment="Center" LastChildFill="False">

                    <ToggleButton IsChecked="True" ToolTip="Enable Vertical Sync" Margin="0,0,6,0"
                                  Style="{StaticResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource VerticalSyncIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <ToggleButton IsChecked="True" ToolTip="Enable Seek Scrubbing" Margin="0,0,6,0"
                                  Style="{StaticResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource ScrubbingIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <ToggleButton Name="SoundMenuButton" IsChecked="True" Margin="0,0,6,0"
                                  Style="{StaticResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource AudioMenuIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <!-- Audio popup (Volume / Balance / Speed) -->
                    <Popup IsOpen="{Binding IsChecked, ElementName=SoundMenuButton, Mode=TwoWay}"
                           StaysOpen="False" Name="SoundMenuPopup"
                           PopupAnimation="Fade" Placement="Top"
                           PlacementTarget="{Binding ElementName=SoundMenuButton}"
                           VerticalOffset="-4" HorizontalOffset="-20">
                        <Border Background="{StaticResource PopupBackgroundBrush}"
                                BorderBrush="#28FFFFFF" BorderThickness="1" CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="24"
                                                  ShadowDepth="4" Opacity="0.65"/>
                            </Border.Effect>
                            <Grid Width="280" Margin="16,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"       Value="#77FFFFFF"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize"          Value="11"/>
                                    </Style>
                                </Grid.Resources>

                                <TextBlock Grid.Row="0" Grid.Column="0">Volume</TextBlock>
                                <Slider   Grid.Row="0" Grid.Column="1"
                                          IsEnabled="{Binding Controller.IsAudioControlEnabled}"
                                          Style="{DynamicResource CustomSliderStyle}"
                                          Minimum="0.0" Maximum="1.0"
                                          Value="{Binding MediaElement.Volume}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" TextAlignment="Right"/>

                                <TextBlock Grid.Row="1" Grid.Column="0">Balance</TextBlock>
                                <Slider   Grid.Row="1" Grid.Column="1"
                                          IsEnabled="{Binding Controller.IsAudioControlEnabled}"
                                          Style="{DynamicResource CustomSliderStyle}"
                                          Minimum="-1.0" Maximum="1.0"
                                          Value="{Binding MediaElement.Balance}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" TextAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="0">Speed</TextBlock>
                                <Slider   Grid.Row="2" Grid.Column="1"
                                          IsEnabled="{Binding Controller.IsSpeedRatioEnabled}"
                                          Style="{DynamicResource CustomSliderStyle}"
                                          Minimum="0.0" Maximum="8.0"
                                          Value="{Binding MediaElement.SpeedRatio}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" TextAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Popup>

                    <ToggleButton Name="MuteUnmuteButton"
                                  Style="{StaticResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource UnmuteIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <ToggleButton Name="ClosedCaptionsButton"
                                  Style="{StaticResource ModernToggleButtonStyle}">
                        <TextBlock Text="CC" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </ToggleButton>
                </DockPanel>

                <!-- CENTER: Pause · Play (gradient) · Stop -->
                <DockPanel Name="CenterControls" HorizontalAlignment="Center"
                           Grid.Column="1" VerticalAlignment="Center" LastChildFill="False">

                    <Button Style="{StaticResource ModernButtonStyle}"  Margin="0,0,10,0" Command="{Binding Commands.PauseCommand}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource PauseIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <!-- Play button — gradient + glow -->
                    <Button Style="{StaticResource PlayButtonStyle}"  Margin="0,0,10,0" Command="{Binding Commands.PlayCommand}">
                        <Path Stretch="Uniform" Margin="1,0,0,0"
                              Data="{StaticResource PlayIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <Button Style="{StaticResource ModernButtonStyle}"  Margin="0,0,10,0" Command="{Binding Commands.StopCommand}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource StopIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </DockPanel>

                <!-- RIGHT: repeat · close · fullscreen · debug · menu -->
                <DockPanel Name="RightControls" HorizontalAlignment="Right"
                           Grid.Column="2" VerticalAlignment="Center" LastChildFill="False">

                    <ToggleButton Style="{StaticResource ModernToggleButtonStyle}" Margin="0,0,6,0"
                                  ToolTip="Enable Looping">
                        <Path Stretch="Uniform"
                              Data="{StaticResource RepeatIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <Button Style="{StaticResource ModernButtonStyle}" Margin="0,0,6,0" Command="{Binding Commands.CloseCommand}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource CloseIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>

                    <Button Name="ToggleFullscreenButton"
                            Style="{StaticResource ModernButtonStyle}" Margin="0,0,6,0">
                        <Path Stretch="Uniform"
                              Data="{StaticResource ToggleFullscreenIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>

                    <ToggleButton IsChecked="{Binding IsPropertiesPanelOpen}" Margin="0,0,6,0"
                                  Name="OpenDebugButton"
                                  Style="{DynamicResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource OpenDebugIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>

                    <ToggleButton IsChecked="{Binding IsPlaylistPanelOpen}"
                                  Name="OpenMenuButton"
                                  Style="{DynamicResource ModernToggleButtonStyle}">
                        <Path Stretch="Uniform"
                              Data="{StaticResource OpenMenuIcon}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.8" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </ToggleButton>
                </DockPanel>

            </Grid>
        </Grid>
    </Grid>
</UserControl>

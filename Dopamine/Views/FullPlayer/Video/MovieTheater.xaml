<UserControl x:Class="Dopamine.Views.FullPlayer.Video.MovieTheater"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Dopamine.Views.FullPlayer.Video"
             xmlns:controls="clr-namespace:Dopamine.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="Transparent" 
                            BorderThickness="1" 
                            CornerRadius="8">

                            <ContentPresenter />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#252525"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="Gray">
        <Grid x:Name="BrowserPage" Visibility="Visible" Background="#121212">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="1" Margin="20,0,20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="12 items  ·  Last updated: Mar 15, 2024" Foreground="#888888" Margin="0,0,10,0"/>
                    <TextBlock Text="Total: ~56.8 GB" Foreground="#888888"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox Width="200" Background="#202020" Foreground="White" BorderThickness="0" Height="30" VerticalContentAlignment="Center" Padding="10,0"/>
                    <Button Content="Sort" Background="#202020" Foreground="White" Width="60" Margin="10,0,0,0" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <ListBox x:Name="VideoListBox" Grid.Row="2" Margin="10,0"
             Background="Transparent" BorderThickness="0"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             SelectionChanged="VideoListBox_SelectionChanged">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Height="210" Margin="4" Background="#1E1E1E" CornerRadius="8" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="145"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!--res 4k / duration-->
                                <Grid Grid.Row="0">
                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>

                                    <Border Background="#007ACC" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Padding="6,2" CornerRadius="3">
                                        <TextBlock Text="{Binding Resolution}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>

                                    <Border Background="Black" Opacity="0.75" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8" Padding="6,2" CornerRadius="3">
                                        <TextBlock Text="{Binding Duration}" Foreground="White" FontSize="11"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Margin="12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,4,0,0">
                                        <Border Background="#2D2D2D" Padding="4,1" CornerRadius="2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Format}" Foreground="#AAA" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="{Binding Size}" Foreground="#888" FontSize="12"/>
                                        <TextBlock Text="  ·  " Foreground="#555" FontSize="12"/>
                                        <TextBlock Text="{Binding ModifiedDate}" Foreground="#888" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        
        
        <Grid x:Name="PlayerPage" Visibility="Collapsed" Background="#0C0C0C">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#121212" VerticalAlignment="Center">
                    <Button Content="← Back" Click="BackButton_Click" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0"/>
                    <TextBlock x:Name="PlayingTitle" Text="Iceland Northern Lights Timelapse" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Background="#2D2D2D" Margin="10,0" Padding="5,2" CornerRadius="3" VerticalAlignment="Center">
                        <TextBlock Text="4K UHD" Foreground="#007ACC" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <controls:MoviePlayer x:Name="MoviePlayer" Grid.Row="1"/>
            </Grid>

            <Grid Grid.Column="1" Background="#141414" Margin="1,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20">
                    <TextBlock x:Name="DetailTitle" Text="Title" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <TextBlock Text="Duration" Foreground="#888"/>
                        <TextBlock x:Name="DetailDuration" Text="4:32" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Size" Foreground="#888"/>
                        <TextBlock x:Name="DetailSize" Text="1.2 GB" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Format" Foreground="#888"/>
                        <TextBlock x:Name="DetailFormat" Text="MP4" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Modified" Foreground="#888"/>
                        <TextBlock x:Name="DetailDate" Text="Mar 15, 2024" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <Separator Background="#222" Margin="0,15,0,5"/>
                    <TextBlock Text="UP NEXT" Foreground="#888" FontSize="12" FontWeight="Bold"/>
                </StackPanel>

                <ListBox x:Name="SideVideoListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="SideVideoListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="{Binding ThumbnailUrl}" Height="45" Stretch="UniformToFill"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Duration}" Foreground="#666" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
